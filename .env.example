# Moomoo Alpha Console - Environment Configuration

# Broker Mode: mock | paper | moomoo
BROKER_MODE=mock

# Master trading enable flag
TRADING_ENABLED=false

# Backend debug mode
DEBUG=true

# Database URL (SQLite default)
DATABASE_URL=sqlite+aiosqlite:///./data/moomoo_alpha.db

# Moomoo OpenD connection (only used when BROKER_MODE=moomoo)
OPEND_HOST=127.0.0.1
OPEND_PORT=11111

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/console.log

# Risk Limits
MAX_POSITION_PCT=5.0
STARTER_POSITION_PCT=2.0
MAX_RISK_PER_TRADE_PCT=0.5
DAILY_LOSS_LIMIT_PCT=2.0
MAX_DRAWDOWN_SOFT_PCT=5.0
MAX_DRAWDOWN_HARD_PCT=8.0
MAX_QUOTE_AGE_SECONDS=10

# Minimum equity required for trading
MIN_EQUITY_FOR_TRADING=500.0

# Trading universe
UNIVERSE_SYMBOLS='["QQQM","META","AMZN","MSFT","SIF","MU","KOID","NVDA","MP","TER","AMBA"]'
